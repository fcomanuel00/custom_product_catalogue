<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         Vista formulario del WIZARD
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_product_catalogue_wizard_form" model="ir.ui.view">
        <field name="name">product.catalogue.wizard.form</field>
        <field name="model">product.catalogue.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Catálogo">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>

                    <group>
                        <group string="Selección de productos">
                            <field name="filter_mode" widget="radio"/>
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   invisible="filter_mode != 'by_products'"
                                   required="filter_mode == 'by_products'"/>
                            <field name="category_ids"
                                   widget="many2many_tags"
                                   invisible="filter_mode != 'by_categories'"
                                   required="filter_mode == 'by_categories'"/>
                            <field name="only_can_be_sold"/>
                            <field name="website_sale_installed" invisible="1"/>
                            <field name="only_website_published"
                                   invisible="not website_sale_installed"/>
                        </group>
                        <group string="Tarifa y diseño">
                            <field name="pricelist_id"/>
                            <field name="style"/>
                            <field name="boxes_per_row" invisible="style != '4'"/>
                            <field name="image_size"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Campos a mostrar" name="fields_to_show">
                            <group>
                                <group>
                                    <field name="show_price"/>
                                    <field name="show_description"/>
                                    <field name="show_reference"/>
                                </group>
                                <group>
                                    <field name="show_uom"/>
                                    <field name="show_category"/>
                                </group>
                            </group>
                        </page>
                        <page string="Cabecera y pie" name="header_footer">
                            <p class="text-muted">
                                El contenido HTML de cabecera/pie aparecerá en el PDF generado.
                                Si además subes PDFs de portada/contraportada, se unirán al documento final.
                            </p>
                            <group>
                                <field name="header_html" nolabel="1"
                                       placeholder="Texto o HTML de cabecera..."/>
                            </group>
                            <group>
                                <field name="footer_html" nolabel="1"
                                       placeholder="Texto o HTML de pie..."/>
                            </group>
                            <group string="PDFs adjuntos (opcional)">
                                <field name="header_pdf" filename="header_pdf_filename"/>
                                <field name="header_pdf_filename" invisible="1"/>
                                <field name="footer_pdf" filename="footer_pdf_filename"/>
                                <field name="footer_pdf_filename" invisible="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_generate"
                            string="Generar catálogo"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         Acción que abre el WIZARD
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="action_product_catalogue_wizard" model="ir.actions.act_window">
        <field name="name">Nuevo Catálogo</field>
        <field name="res_model">product.catalogue.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

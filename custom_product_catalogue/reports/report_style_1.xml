<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        ESTILO 1 — Tabla con imagen pequeña.
        Producto padre como fila de cabecera; si tiene variantes, cada variante
        aparece sangrada debajo con su imagen propia (o la del padre) y precio.
    -->
    <template id="report_style_1">
        <table class="o_cat_table">
            <thead>
                <tr>
                    <th style="width: 80px;">Imagen</th>
                    <th t-if="doc.show_reference" style="width: 80px;">Ref.</th>
                    <th>Producto</th>
                    <th t-if="doc.show_description">Descripción</th>
                    <th t-if="doc.show_uom" style="width: 60px;">UdM</th>
                    <th t-if="doc.show_price" style="width: 90px; text-align: right;">Precio</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="doc._get_sorted_products()" t-as="product">
                    <!-- ──── Fila del producto PADRE ──── -->
                    <tr class="o_cat_parent_row">
                        <td>
                            <img t-if="product.image_128"
                                 t-att-src="image_data_uri(product.image_128)"
                                 t-attf-style="max-height: {{doc._get_image_size_px()}}px; max-width: {{doc._get_image_size_px()}}px;"/>
                        </td>
                        <td t-if="doc.show_reference">
                            <span t-out="product.default_code or '-'"/>
                        </td>
                        <td>
                            <strong t-out="product.name"/>
                            <div t-if="doc.show_category" class="text-muted" style="font-size: 10px;">
                                <t t-out="product.categ_id.complete_name"/>
                            </div>
                        </td>
                        <td t-if="doc.show_description">
                            <span t-out="product.description_sale or product.description or ''"/>
                        </td>
                        <td t-if="doc.show_uom">
                            <span t-out="product.uom_id.name"/>
                        </td>
                        <td t-if="doc.show_price" style="text-align: right;">
                            <!-- Si tiene variantes reales, no pintamos precio aquí (cada variante puede tener el suyo) -->
                            <t t-if="not doc._has_real_variants(product)">
                                <span t-out="doc.get_product_price(product)"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </t>
                            <span t-else="" class="text-muted" style="font-size: 10px;">ver variantes</span>
                        </td>
                    </tr>

                    <!-- ──── Filas de VARIANTES (si hay más de 1) ──── -->
                    <t t-if="doc._has_real_variants(product)">
                        <t t-foreach="doc._get_variants(product)" t-as="variant">
                            <tr class="o_cat_variant_row">
                                <td style="padding-left: 20px;">
                                    <!-- variant.image_128 ya devuelve la del padre si la variante no tiene foto propia -->
                                    <t t-set="var_img_size" t-value="int(doc._get_image_size_px() * 0.8)"/>
                                    <img t-if="variant.image_128"
                                         t-att-src="image_data_uri(variant.image_128)"
                                         t-attf-style="max-height: {{var_img_size}}px; max-width: {{var_img_size}}px;"/>
                                </td>
                                <td t-if="doc.show_reference">
                                    <span t-out="variant.default_code or '-'" style="font-size: 10px;"/>
                                </td>
                                <td style="padding-left: 20px;">
                                    <span t-out="doc._get_variant_attrs_text(variant)"
                                          style="font-size: 11px; color: #555;"/>
                                </td>
                                <td t-if="doc.show_description"/>
                                <td t-if="doc.show_uom">
                                    <span t-out="variant.uom_id.name" style="font-size: 10px;"/>
                                </td>
                                <td t-if="doc.show_price" style="text-align: right;">
                                    <span t-out="doc.get_variant_price(variant)"
                                          t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </td>
                            </tr>
                        </t>
                    </t>
                </t>
            </tbody>
        </table>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Categoría de módulo (ir.module.category):
            Sigue existiendo en Odoo 19, pero ya NO se enlaza desde res.groups.
            En su lugar, res.groups apunta a un `res.groups.privilege`,
            y éste último es el que sí apunta a la `ir.module.category`.
        -->
        <record id="module_category_product_catalogue" model="ir.module.category">
            <field name="name">Catálogos de Productos</field>
            <field name="description">Gestión de catálogos de productos</field>
            <field name="sequence">20</field>
        </record>

        <!--
            Nuevo en Odoo 19: res.groups.privilege.
            Actúa como el antiguo "category_id" de los grupos. Permite agrupar
            varios res.groups bajo el mismo bloque en Ajustes → Usuarios.
        -->
        <record id="privilege_product_catalogue" model="res.groups.privilege">
            <field name="name">Catálogos de Productos</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="module_category_product_catalogue"/>
        </record>

        <!-- Usuario: puede ver los catálogos generados, pero no crear ni enviar -->
        <record id="group_catalogue_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="privilege_id" ref="privilege_product_catalogue"/>
            <field name="comment">Puede consultar los catálogos generados y descargar los PDFs.</field>
        </record>

        <!-- Gestor: puede crear catálogos, enviarlos por email y borrarlos -->
        <record id="group_catalogue_manager" model="res.groups">
            <field name="name">Gestor</field>
            <field name="privilege_id" ref="privilege_product_catalogue"/>
            <field name="implied_ids" eval="[(4, ref('group_catalogue_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
            <field name="comment">Puede generar nuevos catálogos y enviarlos a los clientes.</field>
        </record>

    </data>
</odoo>
